{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "PitCrew": {
    "Authentication": {
      "Mode": "GitHub",
      "GitHubClientId": "",
      "GitHubClientSecret": "",
      "SystemAdministratorGitHubIds": [],
      "DataProtectionKeyPath": "data/data-protection-keys",
      "DevelopmentGitHubUserId": "0",
      "DevelopmentGitHubLogin": "local-operator",
      "DevelopmentDisplayName": "Local operator",
      "DevelopmentAvatarUrl": ""
    },
    "ReverseProxy": {
      "KnownProxyAddresses": []
    },
    "Dashboard": {
      "ConnectorPollSeconds": 15,
      "NodeOfflineAfterSeconds": 60,
      "EnrollmentCodeLifetimeMinutes": 15
    },
    "Sqlite": {
      "DatabasePath": "data/pitcrew-dashboard.db"
    }
  },
  "AllowedHosts": "*"
}
